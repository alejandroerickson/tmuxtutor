# ── main ─────────────────────────────────────────────────────────────────────

trap "save_progress; printf '\n\n  ${C_MUTED}Progress saved. Run ${C_ACCENT}$(basename "$0")${C_MUTED} to continue.${R}\n\n'; exit 0" INT

main() {
  load_progress

  if [ "$CURRENT" -ge "$TOTAL" ]; then
    show_completion
    return
  fi

  local restarting=false

  if [ "$CURRENT" -gt 0 ]; then
    cls
    echo
    printf "  ${C_ACCENT}${B}tmux tutor${R}\n"
    echo
    printf "  ${C_MUTED}Welcome back. You left off at lesson %d / %d.${R}\n\n" "$((CURRENT + 1))" "$TOTAL"
    draw_dots "$((CURRENT + 1))"
    echo
    hr
    printf "\n  ${C_MUTED}[${C_TEXT}c${C_MUTED}] continue  [${C_TEXT}r${C_MUTED}] restart  [${C_TEXT}q${C_MUTED}] quit${R}  "
    while true; do
      local action
      read -rsn1 action || true
      case "${action:-}" in
        c|C|"") break ;;
        r|R) CURRENT=0; save_progress; restarting=true; break ;;
        q|Q) echo; exit 0 ;;
      esac
    done
  fi

  if [ "$CURRENT" -eq 0 ] && ! $restarting; then
    show_intro
  fi

  local i=$((CURRENT + 1))
  while [ "$i" -le "$TOTAL" ]; do
    run_lesson "$i"
    local rc=$?
    if [ "$rc" -eq 2 ] && [ "$i" -gt 1 ]; then
      i=$((i - 1))
      CURRENT=$((i - 1))
      save_progress
    else
      CURRENT=$i
      save_progress
      i=$((i + 1))
    fi
  done

  show_completion
}

main "$@"
