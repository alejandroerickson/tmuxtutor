lesson_12_verify() {
  V_CMD="tmux show-options -gv mouse; tmux show-window-options -gv mode-keys"
  if ! tmux list-sessions &>/dev/null; then
    V_OUT="(no tmux server running)"
    V_MSG="No tmux server found. Start a session first: tmux new -s learn"
    return 1
  fi
  local mouse_val mode_val
  mouse_val=$(tmux show-options -gv mouse 2>/dev/null || echo "off")
  mode_val=$(tmux show-window-options -gv mode-keys 2>/dev/null || echo "emacs")
  V_OUT="mouse=$mouse_val  mode-keys=$mode_val"
  local issues=""
  [ "$mouse_val" != "on" ] && issues="mouse is $mouse_val (need: on)"
  [ "$mode_val" != "vi" ] && issues="${issues:+$issues; }mode-keys is $mode_val (need: vi)"
  if [ -z "$issues" ]; then
    V_MSG="Mouse enabled, vi keys active!"
    return 0
  fi
  V_MSG="$issues"
  return 1
}

