lesson_14_verify() {
  V_CMD="tmux list-windows -t '=project' -F '#{window_name}: #{window_panes} pane(s)'"
  if ! tmux has-session -t '=project' 2>/dev/null; then
    V_OUT="(session 'project' not found)"
    V_MSG="Create the session: tmux new -s project"
    return 1
  fi
  local raw
  raw=$(tmux list-windows -t '=project' -F $'#{window_name}\t#{window_panes}' 2>/dev/null || true)

  local has_editor=false editor_panes=0 has_shell=false
  local wname wpanes display=""
  while IFS=$'\t' read -r wname wpanes; do
    [ -z "$wname" ] && continue
    display="${display}${wname}: ${wpanes} pane(s)
"
    [ "$wname" = "editor" ] && { has_editor=true; editor_panes=$wpanes; }
    [ "$wname" = "shell" ] && has_shell=true
  done <<< "$raw"
  V_OUT="${display%$'\n'}"

  local issues=""
  $has_editor || issues="missing 'editor' window"
  $has_shell || issues="${issues:+$issues; }missing 'shell' window"
  if $has_editor && [ "$editor_panes" -lt 2 ]; then
    issues="${issues:+$issues; }'editor' needs 2+ panes (has $editor_panes)"
  fi

  if [ -z "$issues" ]; then
    V_MSG="Workspace looks great!"
    return 0
  fi
  V_MSG="Not quite: $issues"
  return 1
}

