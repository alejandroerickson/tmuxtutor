lesson_9_verify() {
  V_CMD="grep -E 'mouse|mode-keys|history-limit' ~/.tmux.conf"
  if [ ! -f "${HOME}/.tmux.conf" ]; then
    V_OUT="(~/.tmux.conf does not exist)"
    V_MSG="Create ~/.tmux.conf with the settings shown in the lesson."
    return 1
  fi
  local issues=""
  local found=""

  if grep -q 'mouse on' "${HOME}/.tmux.conf" 2>/dev/null; then
    found="${found}mouse on, "
  else
    issues="${issues}missing 'mouse on'; "
  fi

  if grep -q 'mode-keys vi' "${HOME}/.tmux.conf" 2>/dev/null; then
    found="${found}mode-keys vi, "
  else
    issues="${issues}missing 'mode-keys vi'; "
  fi

  if grep -q 'history-limit' "${HOME}/.tmux.conf" 2>/dev/null; then
    found="${found}history-limit, "
  else
    issues="${issues}missing 'history-limit'; "
  fi

  V_OUT="found in file: ${found%,*}"

  if tmux list-sessions &>/dev/null; then
    local mouse_val hist_val
    mouse_val=$(tmux show-options -gv mouse 2>/dev/null || echo "off")
    hist_val=$(tmux show-options -gv history-limit 2>/dev/null || echo "0")
    V_OUT="${V_OUT}
live: mouse=$mouse_val  history-limit=$hist_val"

    if [ "$mouse_val" != "on" ]; then
      issues="${issues}mouse not active (reload config: tmux source-file ~/.tmux.conf); "
    fi
    if [ "$hist_val" -lt 50000 ] 2>/dev/null; then
      issues="${issues}history-limit is $hist_val (need >= 50000, reload config); "
    fi
  fi

  if [ -z "$issues" ]; then
    V_MSG="Config file and live settings look good!"
    return 0
  fi
  V_MSG="${issues%;*}"
  return 1
}

