  cmd "tmux send-keys -t dev:logs 'echo LOGS_READY' Enter"
  echo
  printf "  ${C_MUTED}This creates session \"dev\" with:${R}\n"
  printf "  ${C_MUTED}  - window \"editor\" (2 panes side by side)${R}\n"
  printf "  ${C_MUTED}  - window \"logs\"${R}\n"
  printf "  ${C_MUTED}  - marker text sent to each so we can verify${R}\n"
