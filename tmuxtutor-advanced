  printf "  ${C_MUTED}${C_ACCENT}-${C_MUTED} looks like a horizontal divider  (stacked)${R}\n"
  printf "  ${C_MUTED}${C_ACCENT}-c \"#{pane_current_path}\"${C_MUTED} opens the new pane in the same directory${R}\n"
  echo
  printf "  ${C_TEXT}Reload the config:${R}\n"
  echo
