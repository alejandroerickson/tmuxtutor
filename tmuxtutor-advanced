    issues="${issues}session 'remote' not found (tmux new -d -s remote); "
    V_OUT=$(printf "%b" "$detail")
    V_MSG="${issues%;*}"
    return 1
  fi
  detail="${detail}session: remote exists\n"

  # Check marker text
  local buf
  buf=$(tmux capture-pane -t 'remote' -p 2>/dev/null || true)
  if echo "$buf" | grep -q 'SSH_WORKFLOW_TEST'; then
    detail="${detail}marker: SSH_WORKFLOW_TEST found\n"
  else
    issues="${issues}SSH_WORKFLOW_TEST not found in session (tmux send-keys -t remote 'echo SSH_WORKFLOW_TEST' Enter); "
  fi

  # Check if session is attached (someone SSH'd in and attached)
  local info
  info=$(tmux list-sessions -F '#{session_name} attached=#{session_attached}' 2>/dev/null | grep '^remote ' || true)
  detail="${detail}${info}\n"
  if echo "$info" | grep -q 'attached=0'; then
    issues="${issues}session is detached — SSH in and run: tmux attach -t remote; "
  fi

  V_OUT=$(printf "%b" "$detail")

  if [ -z "$issues" ]; then
    V_MSG="SSH server running, session attached over SSH. The real deal!"
    return 0
  fi
  V_MSG="${issues%;*}"
  return 1
}

