  echo
  printf "  ${C_TEXT}Now try the new bindings:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '|')     ${C_MUTED}split side by side${R}\n"
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '-')     ${C_MUTED}split stacked${R}\n"
  echo
  printf "  ${C_MUTED}Verification checks that both bindings exist in your config${R}\n"
  printf "  ${C_MUTED}and are loaded into the running tmux server.${R}\n"
}

lesson_10_verify() {
  V_CMD="grep 'split-window' ~/.tmux.conf; tmux list-keys -T prefix | grep split-window"
  if [ ! -f "${HOME}/.tmux.conf" ]; then
    V_OUT="(~/.tmux.conf does not exist)"
    V_MSG="Create ~/.tmux.conf with the custom bindings."
    return 1
  fi
  local issues=""
  local detail=""

  if grep -q 'bind.*|.*split-window' "${HOME}/.tmux.conf" 2>/dev/null; then
    detail="${detail}config: | binding found\n"
  else
    issues="${issues}missing 'bind | split-window ...' in ~/.tmux.conf; "
  fi

  if grep -q 'bind.*-.*split-window.*-v' "${HOME}/.tmux.conf" 2>/dev/null; then
    detail="${detail}config: - binding found\n"
  else
    issues="${issues}missing 'bind - split-window -v ...' in ~/.tmux.conf; "
  fi

  if tmux list-sessions &>/dev/null; then
    local keys
    keys=$(tmux list-keys -T prefix 2>/dev/null || true)

    if echo "$keys" | grep -q '^bind-key.*prefix |.*split-window' 2>/dev/null; then
      detail="${detail}live: | → split-window loaded\n"
    else
      issues="${issues}| binding not loaded (run: tmux source-file ~/.tmux.conf); "
    fi

    if echo "$keys" | grep -q '^bind-key.*prefix -.*split-window' 2>/dev/null; then
      detail="${detail}live: - → split-window loaded\n"
    else
      issues="${issues}- binding not loaded (run: tmux source-file ~/.tmux.conf); "
    fi
  fi

  V_OUT=$(printf "%b" "$detail")

  if [ -z "$issues" ]; then
    V_MSG="Custom split bindings configured and active!"
    return 0
  fi
  V_MSG="${issues%;*}"
  return 1
}

