#!/usr/bin/env bash
# tmux tutor (advanced) — interactive lessons with live verification
# Assumes you have completed tmuxtutor (basics).
# Run in one terminal tab; do the work in another.
set -uo pipefail

# ── prereqs ──────────────────────────────────────────────────────────────────

if ! command -v tmux &>/dev/null; then
  echo
  echo "  tmux is not installed. Install it first:"
  echo
  echo "    Ubuntu/Debian:  sudo apt install tmux"
  echo "    macOS:          brew install tmux"
  echo "    Fedora:         sudo dnf install tmux"
  echo "    Arch:           sudo pacman -S tmux"
  echo
  exit 1
fi

if [ -n "${TMUX:-}" ]; then
  echo
  echo "  Warning: you're running this inside tmux."
  echo "  The tutor works best from a regular terminal tab."
  echo "  Open a new tab outside tmux and run it there."
  echo
  read -rp "  Continue anyway? [y/N] " yn
  [[ "$yn" =~ ^[Yy] ]] || exit 0
fi

# ── config ───────────────────────────────────────────────────────────────────

TOTAL=14
PROGRESS_FILE="${HOME}/.tmuxtutor_advanced_progress"

# ── colors ───────────────────────────────────────────────────────────────────

R=$'\033[0m'
B=$'\033[1m'
D=$'\033[2m'

C_TEXT=$'\033[38;5;252m'
C_MUTED=$'\033[38;5;244m'
C_ACCENT=$'\033[38;5;75m'
C_PREFIX=$'\033[38;5;208m'
C_OK=$'\033[38;5;71m'
C_FAIL=$'\033[38;5;167m'
C_TITLE=$'\033[38;5;255m'

BG_KEY=$'\033[48;5;236m'

if ! tput colors &>/dev/null || [ "$(tput colors 2>/dev/null || echo 0)" -lt 256 ]; then
  R='' B='' D=''
  C_TEXT='' C_MUTED='' C_ACCENT='' C_PREFIX='' C_OK='' C_FAIL='' C_TITLE=''
  BG_KEY=''
fi

# ── drawing helpers ──────────────────────────────────────────────────────────

COLS=$(tput cols 2>/dev/null || echo 80)
[ "$COLS" -gt 88 ] && COLS=88

hr() {
  printf "  ${C_MUTED}${D}"
  printf '%*s' "$((COLS - 4))" '' | tr ' ' '─'
  printf "${R}\n"
}

cls() { clear 2>/dev/null || printf '\033[2J\033[H'; }

pfx() { printf "${BG_KEY}${C_PREFIX}${B} %s ${R}" "$*"; }
key() { printf "${BG_KEY}${C_ACCENT} %s ${R}" "$*"; }
then_() { printf " ${C_MUTED}then${R} "; }
cmd() { printf "  ${C_OK}\$${R} ${C_TEXT}%s${R}\n" "$*"; }
tcmd() { printf "  ${C_OK}:${R} ${C_TEXT}%s${R}\n" "$*"; }
conf() { printf "  ${C_TEXT}%s${R}\n" "$*"; }

draw_dots() {
  local active=$1 i
  printf "  "
  for ((i = 1; i <= TOTAL; i++)); do
    if [ "$i" -lt "$active" ]; then
      printf "${C_OK}●${R}"
    elif [ "$i" -eq "$active" ]; then
      printf "${C_ACCENT}◉${R}"
    else
      printf "${C_MUTED}○${R}"
    fi
    [ "$i" -lt "$TOTAL" ] && printf " "
  done
  printf "\n"
}

# ── lesson titles ────────────────────────────────────────────────────────────

TITLES=(
  ""
  "Kill a Session"
  "Switch Between Sessions"
  "Resize Panes"
  "Swap Panes"
  "Pane Layouts"
  "Move Panes Between Windows"
  "Paste and Buffers"
  "Help and Introspection"
  "Edit tmux.conf"
  "Custom Key Bindings"
  "Synchronized Panes"
  "Script a Workspace"
  "SSH and tmux"
  "Build a Dev Environment"
)

draw_header() {
  local num=$1
  echo
  printf "  ${C_ACCENT}${B}tmux tutor — advanced${R}"
  printf "%*s" "$((COLS - 39))" ""
  printf "${C_MUTED}Lesson %d / %d${R}\n" "$num" "$TOTAL"
  draw_dots "$num"
  hr
  echo
  printf "  ${C_TITLE}${B}%s${R}\n" "${TITLES[$num]}"
  echo
}

# ── progress ─────────────────────────────────────────────────────────────────

CURRENT=0

load_progress() {
  [ -f "$PROGRESS_FILE" ] || return 0
  local val
  val=$(cat "$PROGRESS_FILE" 2>/dev/null) || return 0
  if [[ "$val" =~ ^[0-9]+$ ]] && [ "$val" -le "$TOTAL" ]; then
    CURRENT=$val
  fi
}

save_progress() { echo "$CURRENT" > "$PROGRESS_FILE" 2>/dev/null || true; }

# ── verify globals ───────────────────────────────────────────────────────────

V_CMD=""
V_OUT=""
V_MSG=""

# ════════════════════════════════════════════════════════════════════════════
# LESSON 1: KILL A SESSION
# ════════════════════════════════════════════════════════════════════════════

lesson_1_show() {
  printf "  ${C_TEXT}Sessions accumulate. Sometimes you need to ${C_ACCENT}kill${C_TEXT} one.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — Create two throwaway sessions:${R}\n"
  echo
  cmd "tmux new -d -s temp1"
  cmd "tmux new -d -s temp2"
  echo
  printf "  ${C_MUTED}The ${C_PREFIX}-d${C_MUTED} flag creates them in the background (detached).${R}\n"
  printf "  ${C_MUTED}Confirm they exist:${R}\n"
  echo
  cmd "tmux ls"
  echo
  printf "  ${C_TEXT}Step 2 — Kill only ${C_ACCENT}temp1${C_TEXT}:${R}\n"
  echo
  cmd "tmux kill-session -t temp1"
  echo
  printf "  ${C_MUTED}The nuclear option is ${C_TEXT}tmux kill-server${C_MUTED} — it destroys every${R}\n"
  printf "  ${C_MUTED}session. Don't use it here; we need temp2 alive to verify.${R}\n"
}

lesson_1_verify() {
  V_CMD="tmux has-session -t '=temp1'; tmux has-session -t '=temp2'"
  local temp1_alive=false temp2_alive=false
  tmux has-session -t '=temp1' 2>/dev/null && temp1_alive=true
  tmux has-session -t '=temp2' 2>/dev/null && temp2_alive=true

  if ! $temp1_alive && $temp2_alive; then
    V_OUT=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || echo "(none)")
    V_MSG="temp1 killed, temp2 still alive!"
    return 0
  fi

  V_OUT=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || echo "(no tmux server running)")

  if $temp1_alive && $temp2_alive; then
    V_MSG="temp1 is still alive. Kill it: tmux kill-session -t temp1"
    return 1
  fi

  if ! $temp1_alive && ! $temp2_alive; then
    V_MSG="Both sessions are gone — only kill temp1, not the server. Recreate temp2: tmux new -d -s temp2"
    return 1
  fi

  # temp1 alive, temp2 dead (killed the wrong one)
  if ! $temp2_alive; then
    V_MSG="Wrong one! temp2 is gone but temp1 is still alive. Kill temp1, recreate temp2."
    return 1
  fi

  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 2: SWITCH BETWEEN SESSIONS
# ════════════════════════════════════════════════════════════════════════════

lesson_2_show() {
  printf "  ${C_TEXT}When you have multiple sessions, you can ${C_ACCENT}switch${C_TEXT} between them${R}\n"
  printf "  ${C_TEXT}without detaching and reattaching.${R}\n"
  echo
  printf "  ${C_TEXT}First, make sure you have at least 2 sessions. You should${R}\n"
  printf "  ${C_TEXT}still have temp2 from lesson 1. Create another if needed:${R}\n"
  echo
  cmd "tmux new -d -s work"
  echo
  printf "  ${C_TEXT}Attach to one of them:${R}\n"
  echo
  cmd "tmux attach -t work"
  echo
  printf "  ${C_TEXT}Now switch between sessions using any of these:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 's')   ${C_MUTED}interactive session list${R}\n"
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ')')   ${C_MUTED}next session${R}\n"
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '(')   ${C_MUTED}previous session${R}\n"
  echo
  printf "  ${C_MUTED}Or open the command prompt and type:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ':')   ${C_MUTED}then${R} ${C_TEXT}switch-client -t temp2${R}\n"
}

lesson_2_verify() {
  V_CMD="tmux list-sessions -F '#{session_name} attached=#{session_attached}'"
  if ! tmux list-sessions &>/dev/null; then
    V_OUT="(no tmux server running)"
    V_MSG="No tmux server found. Create sessions first."
    return 1
  fi
  local sessions
  sessions=$(tmux list-sessions -F '#{session_name} attached=#{session_attached}' 2>/dev/null || true)
  V_OUT="$sessions"
  local count attached
  count=$(echo "$sessions" | grep -c . 2>/dev/null) || count=0
  attached=$(echo "$sessions" | grep -c 'attached=1' 2>/dev/null) || attached=0
  if [ "$count" -ge 2 ] && [ "$attached" -ge 1 ]; then
    V_MSG="$count sessions found, $attached attached. Ready to switch!"
    return 0
  fi
  local issues=""
  [ "$count" -lt 2 ] && issues="only $count session(s) — need at least 2"
  [ "$attached" -lt 1 ] && issues="${issues:+$issues; }no session is attached — attach to one first"
  V_MSG="$issues"
  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 3: RESIZE PANES
# ════════════════════════════════════════════════════════════════════════════

lesson_3_show() {
  printf "  ${C_TEXT}Time to work with pane geometry. First, set up a workspace.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — Create session \"adv\" with a named window:${R}\n"
  echo
  cmd "tmux new -d -s adv -n resize"
  echo
  printf "  ${C_TEXT}Step 2 — Split vertically (side by side):${R}\n"
  echo
  cmd "tmux split-window -h -t '=adv:=resize'"
  echo
  printf "  ${C_MUTED}Or attach and use $(pfx 'Ctrl+b')$(then_)$(key '%%')${R}\n"
  echo
  printf "  ${C_TEXT}Step 3 — Attach and make the ${C_ACCENT}right pane noticeably wider${C_TEXT}:${R}\n"
  echo
  cmd "tmux attach -t adv"
  echo
  printf "  ${C_TEXT}Small steps:${R}   $(pfx 'Ctrl+b')$(then_)$(key 'Ctrl+Right')   ${C_MUTED}repeat several times${R}\n"
  printf "  ${C_TEXT}Precise:${R}       $(pfx 'Ctrl+b')$(then_)$(key ':')   ${C_MUTED}then${R} ${C_TEXT}resize-pane -R 20${R}\n"
  echo
  printf "  ${C_PREFIX}Tip:${C_MUTED} The command prompt supports ${C_TEXT}Tab${C_MUTED} completion — type ${C_TEXT}resi${C_MUTED}${R}\n"
  printf "  ${C_MUTED}then press Tab to complete ${C_TEXT}resize-pane${C_MUTED}. Works for all tmux commands.${R}\n"
  echo
  printf "  ${C_MUTED}Goal: the right pane (pane 1) should be wider than 55%% of the window.${R}\n"
}

lesson_3_verify() {
  V_CMD="tmux list-panes -t '=adv:=resize' -F '#{pane_index} #{pane_width} #{window_width}'"
  if ! tmux has-session -t '=adv' 2>/dev/null; then
    V_OUT="(session 'adv' not found)"
    V_MSG="Create the session: tmux new -d -s adv -n resize"
    return 1
  fi
  local panes
  panes=$(tmux list-panes -t '=adv:=resize' -F '#{pane_index} #{pane_width} #{window_width}' 2>/dev/null) || {
    V_OUT="(window 'resize' not found)"
    V_MSG="No window named 'resize' in session 'adv'. Create it: tmux new-window -t '=adv' -n resize"
    return 1
  }
  V_OUT="$panes"
  local count
  count=$(echo "$panes" | grep -c . 2>/dev/null) || count=0
  if [ "$count" -lt 2 ]; then
    V_MSG="Only $count pane(s) in 'resize'. Split it: Ctrl+b %% or tmux split-window -h -t '=adv:=resize'"
    return 1
  fi
  # Check pane 1 width vs window width
  local pane1_width window_width
  pane1_width=$(echo "$panes" | awk '$1 == 1 { print $2 }')
  window_width=$(echo "$panes" | head -1 | awk '{ print $3 }')
  if [ -z "$pane1_width" ] || [ -z "$window_width" ] || [ "$window_width" -eq 0 ]; then
    V_MSG="Could not read pane dimensions. Make sure pane 1 exists."
    return 1
  fi
  local pct=$(( pane1_width * 100 / window_width ))
  if [ "$pct" -ge 55 ]; then
    V_MSG="Right pane is ${pct}%% of window width. Nicely resized!"
    return 0
  fi
  V_MSG="Right pane is ${pct}%% of window width — need at least 55%%. Keep resizing right."
  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 4: SWAP PANES
# ════════════════════════════════════════════════════════════════════════════

lesson_4_show() {
  printf "  ${C_TEXT}You can ${C_ACCENT}swap${C_TEXT} the positions of two panes without moving${R}\n"
  printf "  ${C_TEXT}yourself or retyping anything.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — In the \"resize\" window of session \"adv\", put some${R}\n"
  printf "  ${C_TEXT}identifying text in each pane. Select pane 0:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 'q')$(then_)$(key '0')   ${C_MUTED}flash pane numbers, then hit 0${R}\n"
  echo
  printf "  ${C_TEXT}Run:${R}\n"
  echo
  cmd "echo PANE_A"
  echo
  printf "  ${C_TEXT}Step 2 — Move to pane 1 and put text there:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 'q')$(then_)$(key '1')   ${C_MUTED}or${R} $(pfx 'Ctrl+b')$(then_)$(key 'o')\n"
  echo
  cmd "echo PANE_B"
  echo
  printf "  ${C_TEXT}Step 3 — Swap the panes (from either pane):${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '{')   ${C_MUTED}swap current pane with the previous one${R}\n"
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '}')   ${C_MUTED}swap current pane with the next one${R}\n"
  echo
  printf "  ${C_MUTED}After swapping, pane 0 should show PANE_B and pane 1 PANE_A.${R}\n"
}

lesson_4_verify() {
  V_CMD="tmux capture-pane -t '=adv:=resize.0' -p; tmux capture-pane -t '=adv:=resize.1' -p"
  if ! tmux has-session -t '=adv' 2>/dev/null; then
    V_OUT="(session 'adv' not found)"
    V_MSG="Session 'adv' is gone. Redo from lesson 3."
    return 1
  fi
  local pane0 pane1
  pane0=$(tmux capture-pane -t '=adv:=resize.0' -p 2>/dev/null) || {
    V_OUT="(could not capture pane 0)"
    V_MSG="Window 'resize' or pane 0 not found. Check lesson 3."
    return 1
  }
  pane1=$(tmux capture-pane -t '=adv:=resize.1' -p 2>/dev/null) || {
    V_OUT="(could not capture pane 1)"
    V_MSG="Pane 1 not found. Make sure 'resize' has 2 panes."
    return 1
  }
  local p0_has_b=false p1_has_a=false p0_has_a=false p1_has_b=false
  echo "$pane0" | grep -q 'PANE_B' && p0_has_b=true
  echo "$pane1" | grep -q 'PANE_A' && p1_has_a=true
  echo "$pane0" | grep -q 'PANE_A' && p0_has_a=true
  echo "$pane1" | grep -q 'PANE_B' && p1_has_b=true
  V_OUT="pane 0: $(echo "$pane0" | grep -o 'PANE_[AB]' | head -1 || echo '(no marker)')  pane 1: $(echo "$pane1" | grep -o 'PANE_[AB]' | head -1 || echo '(no marker)')"
  if $p0_has_b && $p1_has_a; then
    V_MSG="Swapped! Pane 0 has PANE_B, pane 1 has PANE_A."
    return 0
  fi
  if $p0_has_a && $p1_has_b; then
    V_MSG="Not swapped yet. PANE_A is still in pane 0. Use Ctrl+b { or Ctrl+b } to swap."
    return 1
  fi
  if ! $p0_has_a && ! $p0_has_b; then
    V_MSG="No marker found in pane 0. Run 'echo PANE_A' in pane 0 first."
    return 1
  fi
  if ! $p1_has_a && ! $p1_has_b; then
    V_MSG="No marker found in pane 1. Run 'echo PANE_B' in pane 1 first."
    return 1
  fi
  V_MSG="Unexpected state. Echo PANE_A in pane 0, PANE_B in pane 1, then swap."
  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 5: PANE LAYOUTS
# ════════════════════════════════════════════════════════════════════════════

lesson_5_show() {
  printf "  ${C_TEXT}tmux has built-in ${C_ACCENT}layout presets${C_TEXT} that rearrange all panes at once.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — Add a third pane to the \"resize\" window:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '\"')   ${C_MUTED}or${R} $(pfx 'Ctrl+b')$(then_)$(key '%%')   ${C_MUTED}split again${R}\n"
  echo
  printf "  ${C_TEXT}Step 2 — Cycle through layouts:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 'Space')   ${C_MUTED}press repeatedly to cycle${R}\n"
  echo
  printf "  ${C_TEXT}Or set a specific layout via the command prompt:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ':')   ${C_MUTED}then${R} ${C_TEXT}select-layout tiled${R}\n"
  echo
  printf "  ${C_MUTED}Available layouts:${R}\n"
  printf "    ${C_ACCENT}even-horizontal${C_MUTED}   equal columns side by side${R}\n"
  printf "    ${C_ACCENT}even-vertical${C_MUTED}     equal rows stacked${R}\n"
  printf "    ${C_ACCENT}main-horizontal${C_MUTED}   one big pane on top, rest below${R}\n"
  printf "    ${C_ACCENT}main-vertical${C_MUTED}     one big pane on left, rest right${R}\n"
  printf "    ${C_ACCENT}tiled${C_MUTED}             grid — all panes roughly equal${R}\n"
  echo
  printf "  ${C_MUTED}Explore a few, then settle on any layout you like.${R}\n"
}

lesson_5_verify() {
  V_CMD="tmux list-panes -t '=adv:=resize' -F '#{pane_index}: #{pane_width}x#{pane_height}'"
  if ! tmux has-session -t '=adv' 2>/dev/null; then
    V_OUT="(session 'adv' not found)"
    V_MSG="Session 'adv' is gone. Redo from lesson 3."
    return 1
  fi
  local panes
  panes=$(tmux list-panes -t '=adv:=resize' -F '#{pane_index}: #{pane_width}x#{pane_height}' 2>/dev/null) || {
    V_OUT="(window 'resize' not found)"
    V_MSG="Window 'resize' not found in session 'adv'."
    return 1
  }
  V_OUT="$panes"
  local count
  count=$(echo "$panes" | grep -c . 2>/dev/null) || count=0
  if [ "$count" -ge 3 ]; then
    V_MSG="$count panes in 'resize'. Layout exploration complete!"
    return 0
  fi
  V_MSG="Only $count pane(s) in 'resize' — need at least 3. Add another split."
  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 6: MOVE PANES BETWEEN WINDOWS
# ════════════════════════════════════════════════════════════════════════════

lesson_6_show() {
  printf "  ${C_TEXT}Panes can be ${C_ACCENT}broken out${C_TEXT} of a window or ${C_ACCENT}joined${C_TEXT} into another.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — Create a second window called \"staging\":${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 'c')       ${C_MUTED}create a new window${R}\n"
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ',')       ${C_MUTED}rename it to ${C_TEXT}staging${R}\n"
  echo
  printf "  ${C_TEXT}Step 2 — Go back to the \"resize\" window:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key 'w')       ${C_MUTED}window list — select resize${R}\n"
  echo
  printf "  ${C_TEXT}Step 3 — Break the current pane into its own window:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '!')       ${C_MUTED}break-pane — pane becomes a new window${R}\n"
  echo
  printf "  ${C_TEXT}Step 4 — Join that broken-out pane into \"staging\":${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ':')   ${C_MUTED}then:${R}\n"
  echo
  cmd "join-pane -t :staging"
  echo
  printf "  ${C_MUTED}This moves the current pane into the \"staging\" window.${R}\n"
  printf "  ${C_MUTED}Result: window \"staging\" should have 2+ panes.${R}\n"
}

lesson_6_verify() {
  V_CMD="tmux list-panes -t '=adv:=staging' -F '#{pane_index}'"
  if ! tmux has-session -t '=adv' 2>/dev/null; then
    V_OUT="(session 'adv' not found)"
    V_MSG="Session 'adv' is gone. Redo from lesson 3."
    return 1
  fi
  local panes
  panes=$(tmux list-panes -t '=adv:=staging' -F '#{pane_index}: #{pane_width}x#{pane_height}' 2>/dev/null) || {
    V_OUT="(window 'staging' not found in session 'adv')"
    V_MSG="No window named 'staging'. Create one in session 'adv': Ctrl+b c, then Ctrl+b , and type staging."
    return 1
  }
  V_OUT="$panes"
  local count
  count=$(echo "$panes" | grep -c . 2>/dev/null) || count=0
  if [ "$count" -ge 2 ]; then
    V_MSG="Window 'staging' has $count panes. Pane successfully moved!"
    return 0
  fi
  V_MSG="Window 'staging' has only $count pane(s) — need 2+. Break a pane from 'resize' (Ctrl+b !) then join it into 'staging'."
  return 1
}

# ════════════════════════════════════════════════════════════════════════════
# LESSON 7: PASTE AND BUFFERS
# ════════════════════════════════════════════════════════════════════════════

lesson_7_show() {
  printf "  ${C_TEXT}tmux maintains its own ${C_ACCENT}paste buffers${C_TEXT} — independent of the${R}\n"
  printf "  ${C_TEXT}system clipboard. You copy text in copy mode and paste it back.${R}\n"
  echo
  printf "  ${C_TEXT}Step 1 — In any pane of session \"adv\", run:${R}\n"
  echo
  cmd "echo ADVANCED_PASTE_TEST"
  echo
  printf "  ${C_TEXT}Step 2 — Enter copy mode:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '[')\n"
  echo
  printf "  ${C_TEXT}Step 3 — First, make sure vi keys are active:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key ':')     ${C_MUTED}then type: ${C_TEXT}set -g mode-keys vi${R}\n"
  echo
  printf "  ${C_TEXT}Step 4 — Re-enter copy mode and find the text:${R}\n"
  echo
  printf "  $(pfx 'Ctrl+b')$(then_)$(key '[')\n"
  printf "  ${C_MUTED}  ${C_TEXT}/${C_MUTED}ADVANCED_PASTE_TEST${C_TEXT}Enter${C_MUTED}   search for it${R}\n"
  printf "  ${C_MUTED}  ${C_TEXT}Space${C_MUTED}                         start selection${R}\n"
