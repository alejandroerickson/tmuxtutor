}

lesson_12_verify() {
  V_CMD="tmux list-windows -t '=dev' -F '#{window_name}: #{window_panes} pane(s)'"
  if ! tmux has-session -t '=dev' 2>/dev/null; then
    V_OUT="(session 'dev' not found)"
    V_MSG="Create session 'dev' with the scripted commands."
    return 1
  fi
  local raw
  raw=$(tmux list-windows -t '=dev' -F $'#{window_name}\t#{window_panes}' 2>/dev/null || true)
  V_OUT=$(tmux list-windows -t '=dev' -F '#{window_name}: #{window_panes} pane(s)' 2>/dev/null || true)

  local has_editor=false editor_panes=0 has_logs=false
  local wname wpanes
  while IFS=$'\t' read -r wname wpanes; do
    [ -z "$wname" ] && continue
    [ "$wname" = "editor" ] && { has_editor=true; editor_panes=$wpanes; }
    [ "$wname" = "logs" ] && has_logs=true
  done <<< "$raw"

  local issues=""
  $has_editor || issues="missing 'editor' window; "
  $has_logs   || issues="${issues}missing 'logs' window; "
  if $has_editor && [ "$editor_panes" -lt 2 ]; then
    issues="${issues}'editor' has $editor_panes pane(s), need 2+; "
  fi

  if $has_editor; then
    local editor_buf
    editor_buf=$(tmux capture-pane -t '=dev:=editor.0' -p 2>/dev/null || true)
    if echo "$editor_buf" | grep -q 'EDITOR_READY'; then
      V_OUT="${V_OUT}
editor.0: EDITOR_READY found"
    else
      issues="${issues}'EDITOR_READY' not found in editor pane 0; "
    fi
  fi

  if $has_logs; then
    local logs_buf
    logs_buf=$(tmux capture-pane -t '=dev:=logs' -p 2>/dev/null || true)
    if echo "$logs_buf" | grep -q 'LOGS_READY'; then
      V_OUT="${V_OUT}
logs: LOGS_READY found"
    else
      issues="${issues}'LOGS_READY' not found in logs window; "
    fi
  fi

  if [ -z "$issues" ]; then
    V_MSG="Scripted workspace looks perfect!"
    return 0
  fi
  V_MSG="${issues%;*}"
  return 1
}

