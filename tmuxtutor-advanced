lesson_14_verify() {
  V_CMD="tmux list-sessions; tmux list-windows -t '=backend'; tmux list-windows -t '=frontend'"
  local issues=""
  local detail=""

  if ! tmux has-session -t '=backend' 2>/dev/null; then
    issues="${issues}missing session 'backend'; "
  else
    local be_raw
    be_raw=$(tmux list-windows -t '=backend' -F $'#{window_name}\t#{window_panes}' 2>/dev/null || true)
    detail="${detail}backend:\n"

    local has_api=false api_panes=0 has_db=false
    local wname wpanes
    while IFS=$'\t' read -r wname wpanes; do
      [ -z "$wname" ] && continue
      detail="${detail}  $wname: $wpanes pane(s)\n"
      [ "$wname" = "api" ]  && { has_api=true; api_panes=$wpanes; }
      [ "$wname" = "db" ]   && has_db=true
    done <<< "$be_raw"

    $has_api || issues="${issues}backend missing 'api' window; "
    $has_db  || issues="${issues}backend missing 'db' window; "
    if $has_api && [ "$api_panes" -lt 2 ]; then
      issues="${issues}backend:api has $api_panes pane(s), need 2+; "
    fi

    if $has_api; then
      local api_buf
      api_buf=$(tmux capture-pane -t '=backend:=api.0' -p 2>/dev/null || true)
      if echo "$api_buf" | grep -q 'BACKEND_API'; then
        detail="${detail}  api.0: BACKEND_API found\n"
      else
        issues="${issues}BACKEND_API not found in backend:api.0; "
      fi
    fi
  fi

  if ! tmux has-session -t '=frontend' 2>/dev/null; then
    issues="${issues}missing session 'frontend'; "
  else
    local fe_raw
    fe_raw=$(tmux list-windows -t '=frontend' -F $'#{window_name}\t#{window_panes}' 2>/dev/null || true)
    detail="${detail}frontend:\n"

    local has_app=false app_panes=0 has_tests=false
    local wname wpanes
    while IFS=$'\t' read -r wname wpanes; do
      [ -z "$wname" ] && continue
      detail="${detail}  $wname: $wpanes pane(s)\n"
      [ "$wname" = "app" ]   && { has_app=true; app_panes=$wpanes; }
      [ "$wname" = "tests" ] && has_tests=true
    done <<< "$fe_raw"

    $has_app   || issues="${issues}frontend missing 'app' window; "
    $has_tests || issues="${issues}frontend missing 'tests' window; "
    if $has_app && [ "$app_panes" -lt 2 ]; then
      issues="${issues}frontend:app has $app_panes pane(s), need 2+; "
    fi

    if $has_app; then
      local app_buf
      app_buf=$(tmux capture-pane -t '=frontend:=app.0' -p 2>/dev/null || true)
      if echo "$app_buf" | grep -q 'FRONTEND_APP'; then
        detail="${detail}  app.0: FRONTEND_APP found\n"
      else
        issues="${issues}FRONTEND_APP not found in frontend:app.0; "
      fi
    fi
  fi

  V_OUT=$(printf "%b" "$detail")

  if [ -z "$issues" ]; then
    V_MSG="Multi-session dev environment is perfect!"
    return 0
  fi
  V_MSG="${issues%;*}"
  return 1
}

