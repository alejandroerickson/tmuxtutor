  echo
  printf "  ${C_ACCENT}-d${C_MUTED}                   create detached (don't attach immediately)${R}\n"
  printf "  ${C_ACCENT}-t session:window${C_MUTED}    target a specific window${R}\n"
  printf "  ${C_ACCENT}-t session:window.pane${C_MUTED}  target a specific pane${R}\n"
  printf "  ${C_ACCENT}send-keys ... Enter${C_MUTED}  type a command into a pane${R}\n"
  echo
  printf "  ${C_TEXT}Run these commands in your regular shell (not inside tmux):${R}\n"
