show_lesson() {
  local num=$1
  cls
  draw_header "$num"
  "lesson_${num}_show"
  echo
  hr
  if [ "$num" -gt 1 ]; then
    printf "\n  ${C_MUTED}[${C_ACCENT}v${C_MUTED}] verify  [${C_TEXT}b${C_MUTED}] back  [${C_TEXT}s${C_MUTED}] skip  [${C_TEXT}q${C_MUTED}] quit${R}  "
  else
    printf "\n  ${C_MUTED}[${C_ACCENT}v${C_MUTED}] verify  [${C_TEXT}s${C_MUTED}] skip  [${C_TEXT}q${C_MUTED}] quit${R}  "
  fi
  printf '\033[H'
}

show_verify() {
  local passed=$1
  echo
  echo
  if [ "$passed" -eq 0 ]; then
    printf "  ${C_OK}${B}✓ PASSED${R}\n"
  else
    printf "  ${C_FAIL}${B}✗ NOT YET${R}\n"
  fi
  echo
  printf "  ${C_MUTED}\$ %s${R}\n" "$V_CMD"
  if [ -n "$V_OUT" ]; then
    while IFS= read -r line; do
      printf "  ${C_TEXT}  %s${R}\n" "$line"
    done <<< "$V_OUT"
  fi
  echo
  printf "  ${C_TEXT}%s${R}\n" "$V_MSG"
}

run_lesson() {
  local num=$1
  show_lesson "$num"

  while true; do
    local action
    read -rsn1 action || true
    case "${action:-}" in
      v|V)
        cls
        draw_header "$num"
        echo
        printf "  ${C_MUTED}Verifying...${R}"
        sleep 0.3 2>/dev/null || true
        if "lesson_${num}_verify"; then
          show_verify 0
          echo
          hr
          printf "\n  ${C_MUTED}Press any key to continue...${R}"
          read -rsn1 || true
          return 0
        else
          show_verify 1
          echo
          hr
          if [ "$num" -gt 1 ]; then
            printf "\n  ${C_MUTED}[${C_ACCENT}v${C_MUTED}] try again  [${C_TEXT}b${C_MUTED}] back  [${C_TEXT}r${C_MUTED}] review lesson  [${C_TEXT}s${C_MUTED}] skip  [${C_TEXT}q${C_MUTED}] quit${R}  "
          else
            printf "\n  ${C_MUTED}[${C_ACCENT}v${C_MUTED}] try again  [${C_TEXT}r${C_MUTED}] review lesson  [${C_TEXT}s${C_MUTED}] skip  [${C_TEXT}q${C_MUTED}] quit${R}  "
          fi
        fi
        ;;
      b|B)
        if [ "$num" -gt 1 ]; then
          return 2
        fi
        ;;
      r|R)
        show_lesson "$num"
        ;;
      s|S)
        return 0
        ;;
      q|Q)
        save_progress
        echo
        printf "\n\n  ${C_MUTED}Progress saved at lesson %d. Run ${C_ACCENT}$(basename "$0")${C_MUTED} to continue.${R}\n\n" "$num"
        exit 0
        ;;
    esac
  done
}

